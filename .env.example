# Copy this file to apps/studio/.env.local (gitignored).
# Next.js uses apps/studio as its project root, so a repository-root .env file
# is not loaded automatically by `pnpm dev`, `pnpm build`, or `pnpm start`.

# --- ComfyUI backend ---
# cloud（默认：设置了 COMFY_CLOUD_API_KEY 即走 Cloud）
# local（本机 ComfyUI）
# COMFYUI_BACKEND=cloud

# Comfy Cloud API Key：https://platform.comfy.org/profile/api-keys
# 有此 key 时默认连 https://cloud.comfy.org（无需本机 GPU）
COMFY_CLOUD_API_KEY=

# 可选覆盖 Base URL（Cloud 默认 https://cloud.comfy.org；本地默认 http://127.0.0.1:8188）
# COMFYUI_URL=https://cloud.comfy.org

# --- ControlNet（可选）---
# Pose/ControlNet 工作流默认加载 OpenPoseXL2.safetensors（见 packages/core/workflows/*controlnet*.json）。
# Cloud/本机若模型文件名不同，直接改对应 workflow JSON 的 ControlNetLoader.control_net_name。

# --- Studio paths（可选）---
# ICY_ROOT=
# ICY_CONTENT_ROOT=
# ICY_DB_PATH=
