{
  "name": "project-icy",
  "private": true,
  "version": "0.1.0",
  "description": "AI dual-form content studio: anime <-> realistic paired generation",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "db:generate": "pnpm --filter @icy/core db:generate",
    "db:push": "pnpm --filter @icy/core db:push"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "sharp", "unrs-resolver"]
  },
  "packageManager": "pnpm@10.0.0"
}
